# API Configuration Example
# Copy this file to .env and add your actual API keys

# TMDB API Key for movies
# Get your key from: https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# Listen Notes API Key for podcasts  
# Get your key from: https://www.listennotes.com/api/
EXPO_PUBLIC_LISTEN_NOTES_API_KEY=your_listen_notes_api_key_here

# Base URLs (these can remain as defaults)
EXPO_PUBLIC_TMDB_BASE_URL=https://api.themoviedb.org/3
EXPO_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
EXPO_PUBLIC_ITUNES_BASE_URL=https://itunes.apple.com/search
EXPO_PUBLIC_LISTEN_NOTES_BASE_URL=https://listen-api.listennotes.com/api/v2
EXPO_PUBLIC_DEMO_BASE_URL=https://jsonplaceholder.typicode.com